            "content": "def calculate_average_age(users):\n    total_age = 0\n    count = 0\n\n    for user in users:\n        # Check if 'age' exists\n        if 'age' not in user:\n            print(f\"Skipping user {user.get('name', 'Unknown')} - age missing\")\n            continue\n\n        age = user['age']\n\n        # Convert string ages to integers if possible\n        try:\n            age = int(age)\n        except ValueError:\n            print(f\"Skipping user {user.get('name', 'Unknown')} - invalid age\")\n            continue\n\n        total_age += age\n        count += 1\n\n    # Avoid division by zero\n    if count == 0:\n        return 0\n\n    return total_age / count\n\n\n# Test Data\nusers_data = [\n    {\"name\": \"Alice\", \"age\": 25},\n    {\"name\": \"Bob\", \"age\": \"30\"},\n    {\"name\": \"Charlie\"},   # Missing age\n    {\"name\": \"David\", \"age\": \"abc\"}  # Invalid age\n]\n\nprint(\"Starting analysis...\")\navg = calculate_average_age(users_data)\nprint(f\"Average Age: {avg}\")",
